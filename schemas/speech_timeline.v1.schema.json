{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Speech timeline v1",
  "type": "object",
  "required": ["schema_version", "source", "guard_ms", "total_duration_ms", "speech_intervals", "silence_intervals"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "source": {"const": "dubbing_cues.v2"},
    "guard_ms": {"type": "integer", "minimum": 0},
    "total_duration_ms": {"type": ["integer", "null"], "minimum": 0},
    "speech_intervals": {
      "type": "array",
      "items": {"$ref": "#/$defs/speech_interval"}
    },
    "silence_intervals": {
      "type": "array",
      "items": {"$ref": "#/$defs/silence_interval"}
    },
    "source_timing_quality": {"enum": ["word", "cue_fallback", "unavailable"]},
    "source_pause_threshold_ms": {"type": "integer", "minimum": 0},
    "source_speech_intervals": {"type": "array", "items": {"$ref": "#/$defs/source_speech_interval"}},
    "source_silence_intervals": {"type": "array", "items": {"$ref": "#/$defs/source_silence_interval"}}
  },
  "$defs": {
    "speech_interval": {
      "type": "object",
      "required": ["index", "cue_id", "start_ms", "end_ms", "duration_ms", "source_text", "display_text", "spoken_text", "parent_segment_ids", "protected_spans", "risk_flags"],
      "properties": {
        "index": {"type": "integer", "minimum": 0},
        "cue_id": {"type": "string", "pattern": "^cue_"},
        "start_ms": {"type": "integer", "minimum": 0},
        "end_ms": {"type": "integer", "minimum": 0},
        "duration_ms": {"type": "integer", "minimum": 0},
        "source_text": {"type": "string"},
        "display_text": {"type": "string"},
        "spoken_text": {"type": "string"},
        "parent_segment_ids": {"type": "array", "items": {"type": "string"}},
        "protected_spans": {"type": "array", "items": {"type": "object"}},
        "risk_flags": {"type": "array", "items": {"type": "string"}}
      }
    },
    "silence_interval": {
      "type": "object",
      "required": ["gap_id", "position", "start_ms", "end_ms", "duration_ms", "preceding_cue_id", "following_cue_id", "guard_ms", "preserve_pause_ms", "usable_overflow_ms"],
      "properties": {
        "gap_id": {"type": "string", "pattern": "^gap_"},
        "position": {"enum": ["full_track", "before_first", "between_speech", "after_last"]},
        "start_ms": {"type": "integer", "minimum": 0},
        "end_ms": {"type": "integer", "minimum": 0},
        "duration_ms": {"type": "integer", "minimum": 0},
        "preceding_cue_id": {"type": ["string", "null"]},
        "following_cue_id": {"type": ["string", "null"]},
        "guard_ms": {"type": "integer", "minimum": 0},
        "preserve_pause_ms": {"type": "integer", "minimum": 0},
        "usable_overflow_ms": {"type": "integer", "minimum": 0}
      }
    },
    "source_speech_interval": {
      "type": "object",
      "required": ["interval_id", "start_ms", "end_ms", "duration_ms", "word_count", "segment_ids", "cue_ids"],
      "properties": {
        "interval_id": {"type": "string", "pattern": "^source_speech_"},
        "start_ms": {"type": "integer", "minimum": 0},
        "end_ms": {"type": "integer", "minimum": 0},
        "duration_ms": {"type": "integer", "minimum": 0},
        "word_count": {"type": "integer", "minimum": 0},
        "segment_ids": {"type": "array", "items": {"type": "string"}},
        "cue_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "source_silence_interval": {
      "type": "object",
      "required": ["interval_id", "position", "start_ms", "end_ms", "duration_ms"],
      "properties": {
        "interval_id": {"type": "string", "pattern": "^source_silence_"},
        "position": {"enum": ["before_first", "between_speech", "after_last"]},
        "start_ms": {"type": "integer", "minimum": 0},
        "end_ms": {"type": "integer", "minimum": 0},
        "duration_ms": {"type": "integer", "minimum": 0}
      }
    }
  }
}
