{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dubbing cues v1",
  "type": "object",
  "required": ["schema_version", "cues"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "cues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cue_id", "start_ms", "end_ms", "duration_ms", "source_text", "translated_text", "parent_segment_ids"],
        "properties": {
          "cue_id": {"type": "string", "pattern": "^cue_"},
          "start_ms": {"type": "integer", "minimum": 0},
          "end_ms": {"type": "integer", "minimum": 1},
          "duration_ms": {"type": "integer", "minimum": 1},
          "source_text": {"type": "string"},
          "translated_text": {"type": "string"},
          "parent_segment_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1}
        }
      }
    }
  }
}
