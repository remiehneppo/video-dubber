{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Locked high-risk cue review",
  "type": "object",
  "required": ["schema_version", "status", "cues"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "status": {"const": "locked"},
    "cue_set_checksum": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "cues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["cue_id", "review_overrides"],
        "properties": {
          "cue_id": {"type": "string", "pattern": "^cue_"},
          "review_overrides": {"$ref": "#/$defs/review_overrides"}
        }
      }
    }
  },
  "$defs": {
    "review_overrides": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "source_text_normalized": {"type": "string"},
        "display_text": {"type": "string"},
        "spoken_text": {"type": "string"},
        "protected_spans": {"type": "array", "items": {"type": "object"}},
        "start_ms": {"type": "integer", "minimum": 0},
        "end_ms": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    }
  }
}
