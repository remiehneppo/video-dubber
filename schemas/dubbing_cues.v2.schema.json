{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dubbing cues v2",
  "type": "object",
  "required": ["schema_version", "cues"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "domain_profile": {"type": "string"},
    "cues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "cue_id",
          "start_ms",
          "end_ms",
          "duration_ms",
          "source_text",
          "display_text",
          "spoken_text",
          "protected_spans",
          "parent_segment_ids"
        ],
        "properties": {
          "cue_id": {"type": "string", "pattern": "^cue_"},
          "start_ms": {"type": "integer", "minimum": 0},
          "end_ms": {"type": "integer", "minimum": 1},
          "duration_ms": {"type": "integer", "minimum": 1},
          "source_text": {"type": "string"},
          "source_text_raw": {"type": "string"},
          "display_text": {"type": "string"},
          "spoken_text": {"type": "string"},
          "protected_spans": {"type": "array", "items": {"type": "object"}},
          "parent_segment_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "used_terms": {"type": "array", "items": {"type": "string"}},
          "translation_warnings": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
