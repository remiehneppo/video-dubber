{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "High-risk cue review request",
  "type": "object",
  "required": ["schema_version", "domain_profile", "status", "review_scope", "cues"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "domain_profile": {"type": "string", "minLength": 1},
    "cue_set_checksum": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "status": {"const": "required"},
    "review_scope": {"const": "high_risk_cues"},
    "cues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["cue_id", "reason", "source_text_raw", "source_text_normalized", "display_text", "spoken_text", "protected_spans", "normalization_edits", "normalization_suggestions", "risk_flags", "review_overrides"],
        "properties": {
          "cue_id": {"type": "string", "pattern": "^cue_"},
          "reason": {"enum": ["source_normalization_review_required", "asr_timeline_review_required"]},
          "source_text_raw": {"type": "string"},
          "source_text_normalized": {"type": "string"},
          "display_text": {"type": "string"},
          "spoken_text": {"type": "string"},
          "start_ms": {"type": "integer", "minimum": 0},
          "end_ms": {"type": "integer", "minimum": 0},
          "duration_ms": {"type": "integer", "minimum": 0},
          "protected_spans": {"type": "array", "items": {"type": "object"}},
          "normalization_edits": {"type": "array", "items": {"type": "object"}},
          "normalization_suggestions": {"type": "array", "items": {"type": "object"}},
          "risk_flags": {"type": "array", "items": {"type": "string"}},
          "review_overrides": {"$ref": "#/$defs/review_overrides"}
        }
      }
    }
  },
  "$defs": {
    "review_overrides": {
      "type": "object",
      "required": ["source_text_normalized", "display_text", "spoken_text", "protected_spans"],
      "properties": {
        "source_text_normalized": {"type": "string"},
        "display_text": {"type": "string"},
        "spoken_text": {"type": "string"},
        "protected_spans": {"type": "array", "items": {"type": "object"}},
        "start_ms": {"type": "integer", "minimum": 0},
        "end_ms": {"type": "integer", "minimum": 0}
      }
    }
  }
}
